pkgname=calamares-settings-arch
pkgver=24.12
pkgrel=1
pkgdesc="Arch Linux settings and branding for Calamares"
arch=('any')
url="https://github.com/arch-linux-calamares-installer/alci-calamares-config"
license=('GPL')
depends=('calamares')
source=("git+https://github.com/arch-linux-calamares-installer/alci-calamares-config.git")
sha256sums=('SKIP')

package() {
  cd "${srcdir}/alci-calamares-config"
  install -d "${pkgdir}/etc/calamares"
  install -d "${pkgdir}/usr/share/calamares"
  cp -r etc/calamares/* "${pkgdir}/etc/calamares/"
  cp -r usr/share/calamares/* "${pkgdir}/usr/share/calamares/"
}
