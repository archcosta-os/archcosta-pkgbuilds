pkgname=archcosta-settings
pkgver=1.0
pkgrel=7
pkgdesc="System settings and tweaks for ArchCosta"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
depends=('systemd')
source=("etc" "usr")
sha256sums=('SKIP' 'SKIP')

package() {
    # sysctl tweaks
    install -Dm644 "$srcdir/etc/sysctl.d/99-archcosta.conf" \
        "$pkgdir/etc/sysctl.d/99-archcosta.conf"

    # udev rules
    install -Dm644 "$srcdir/etc/udev/rules.d/60-ioschedulers.rules" \
        "$pkgdir/etc/udev/rules.d/60-ioschedulers.rules"

    # systemd units
    install -Dm644 "$srcdir/etc/systemd/zram-generator.conf" \
        "$pkgdir/etc/systemd/zram-generator.conf"
        
    # lite-mode script
    install -Dm755 "$srcdir/usr/lib/archcosta/lite-mode" \
        "$pkgdir/usr/lib/archcosta/lite-mode"
}
