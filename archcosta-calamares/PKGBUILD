pkgname=archcosta-calamares
pkgver=1.0
pkgrel=6
pkgdesc="Calamares settings for ArchCosta"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=("etc")
sha256sums=('SKIP')

package() {
    mkdir -p "$pkgdir/etc/calamares"
    cp -r "$srcdir/etc/calamares/." "$pkgdir/etc/calamares/"
}
