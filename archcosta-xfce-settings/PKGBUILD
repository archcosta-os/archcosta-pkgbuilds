pkgname=archcosta-xfce-settings
pkgver=1.0
pkgrel=3
pkgdesc="ArchCosta XFCE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()

package() {
    if [ -d "$srcdir/etc/skel" ]; then
        install -dm755 "$pkgdir/etc/skel"
        cp -r "$srcdir/etc/skel/." "$pkgdir/etc/skel/"
    fi

    if [ -d "$srcdir/usr" ]; then
        install -dm755 "$pkgdir/usr"
        cp -r "$srcdir/usr/." "$pkgdir/usr/"
    fi
}
