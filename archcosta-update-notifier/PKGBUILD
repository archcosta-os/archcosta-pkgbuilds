pkgname=archcosta-update-notifier
pkgver=1.0
pkgrel=1
pkgdesc="ArchCosta update notifier"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
depends=('archcosta-bash-shared' 'yad' 'libnotify' 'pacman-contrib' 'xdg-utils')
source=("archcosta-update-notifier"
        "archcosta-update-notifier.conf"
        "archcosta-update-notifier.desktop")
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    install -Dm755 archcosta-update-notifier "$pkgdir/usr/bin/archcosta-update-notifier"
    install -Dm644 archcosta-update-notifier.conf "$pkgdir/etc/archcosta-update-notifier.conf"
    install -Dm644 archcosta-update-notifier.desktop "$pkgdir/usr/share/applications/archcosta-update-notifier.desktop"
}
