#!/bin/bash

# ArchCosta Update Utility
# A robust system update wrapper

echo "--------------------------------------------------"
echo "🚀 Starting ArchCosta System Update"
echo "--------------------------------------------------"

# 1. Refresh Keyring
echo ":: Updating keyrings..."
sudo pacman -Sy --needed --noconfirm archlinux-keyring cachyos-keyring 2>/dev/null

# 2. Refresh Mirrors
echo ":: Finding fastest mirrors..."
sudo reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist

# 3. System Update
echo ":: Synchronizing package databases and upgrading system..."
sudo pacman -Syu

# 4. AUR Update (Detect helper)
if command -v paru >/dev/null 2>&1; then
    echo ":: Updating AUR packages with paru..."
    paru -Sua
elif command -v yay >/dev/null 2>&1; then
    echo ":: Updating AUR packages with yay..."
    yay -Sua
fi

# 5. Cleanup
echo ":: Cleaning up package cache..."
sudo pacman -Sc --noconfirm

echo "--------------------------------------------------"
echo "✅ Update Complete!"
echo "--------------------------------------------------"
