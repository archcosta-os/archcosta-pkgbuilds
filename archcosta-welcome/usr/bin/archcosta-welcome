#!/usr/bin/env python3
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk
import os

class WelcomeWindow(Gtk.Window):
    def __init__(self):
        Gtk.Window.__init__(self, title="Welcome to ArchCosta OS")
        self.set_border_width(20)
        self.set_default_size(500, 400)
        self.set_position(Gtk.WindowPosition.CENTER)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        self.add(vbox)

        label = Gtk.Label()
        label.set_markup("<big><b>Welcome to ArchCosta OS</b></big>")
        vbox.pack_start(label, False, False, 0)

        desc = Gtk.Label(label="ArchCosta is a fast, lightweight, and professional distribution based on Arch Linux.")
        desc.set_line_wrap(True)
        vbox.pack_start(desc, False, False, 0)

        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.CENTER)
        vbox.pack_start(grid, True, True, 0)

        btn_update = Gtk.Button(label="Update System")
        btn_update.connect("clicked", self.run_cmd, "xfce4-terminal -e 'sudo pacman -Syu'")
        grid.attach(btn_update, 0, 0, 1, 1)

        btn_apps = Gtk.Button(label="Install Apps")
        btn_apps.connect("clicked", self.run_cmd, "xfce4-appfinder")
        grid.attach(btn_apps, 1, 0, 1, 1)

        btn_web = Gtk.Button(label="Open Browser")
        btn_web.connect("clicked", self.run_cmd, "brave-browser")
        grid.attach(btn_web, 0, 1, 1, 1)

        btn_wiki = Gtk.Button(label="Documentation")
        btn_wiki.connect("clicked", self.run_cmd, "brave-browser https://github.com/archcosta-os/archcosta-wiki")
        grid.attach(btn_wiki, 1, 1, 1, 1)

        btn_github = Gtk.Button(label="GitHub Organization")
        btn_github.connect("clicked", self.run_cmd, "brave-browser https://github.com/archcosta-os")
        grid.attach(btn_github, 0, 2, 2, 1)

        footer = Gtk.Label(label="Built with love for low-end systems.")
        vbox.pack_start(footer, False, False, 0)

    def run_cmd(self, widget, cmd):
        os.system(cmd)

win = WelcomeWindow()
win.connect("destroy", Gtk.main_quit)
win.show_all()
Gtk.main()
