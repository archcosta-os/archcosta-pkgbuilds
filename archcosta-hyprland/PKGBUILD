pkgname=archcosta-hyprland
pkgver=1.0
pkgrel=2
pkgdesc="ArchCosta Hyprland meta-package"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
depends=(
  'hyprland'
  'waybar'
  'swaybg'
  'swaylock'
  'wofi'
  'kitty'
  'archcosta-hyprland-settings'
  'archcosta-settings'
  'archcosta-artwork'
)
package() {
  mkdir -p "$pkgdir/usr/share/archcosta"
  echo "ArchCosta Hyprland Window Manager" > "$pkgdir/usr/share/archcosta/hyprland"
}
