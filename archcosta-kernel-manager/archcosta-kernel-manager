#!/bin/bash

# ArchCosta Kernel Manager

source /usr/share/archcosta/scripts/archcosta-script-lib-yad || exit 1

ListKernels() {
    echo "Kernel|Installed|Repo Version"
    local k
    for k in linux linux-lts linux-zen linux-hardened linux-cachyos; do
        local inst=$(expac -Q %v "$k" 2>/dev/null || echo "-")
        local repo=$(expac -S %v "$k" 2>/dev/null || echo "-")
        echo "$k|$inst|$repo"
    done
}

Main() {
    local choice=$(ListKernels | archcosta_yad --list --column="Kernel" --column="Installed" --column="Repo Version" \
        --title="ArchCosta Kernel Manager" --width=500 --height=400 \
        --button="Install/Update":0 --button="Exit":1)
    
    local retval=$?
    if [ $retval -eq 0 ]; then
        local pkg=$(echo "$choice" | cut -d'|' -f1)
        RunInTerminal "sudo pacman -S --needed $pkg" "Installing $pkg"
    fi
}

Main "$@"
