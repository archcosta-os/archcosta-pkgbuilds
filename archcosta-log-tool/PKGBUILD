pkgname=archcosta-log-tool
pkgver=1.0
pkgrel=1
pkgdesc="ArchCosta log gathering tool"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
depends=('archcosta-bash-shared' 'yad' 'curl' 'hwinfo' 'inxi')
source=("archcosta-log-tool"
        "archcosta-log-tool.desktop")
sha256sums=('SKIP' 'SKIP')

package() {
    install -Dm755 archcosta-log-tool "$pkgdir/usr/bin/archcosta-log-tool"
    install -Dm644 archcosta-log-tool.desktop "$pkgdir/usr/share/applications/archcosta-log-tool.desktop"
}
