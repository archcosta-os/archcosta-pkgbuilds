#!/bin/bash

# ArchCosta Log Tool

source /usr/share/archcosta/scripts/archcosta-script-lib-yad || exit 1

FILE_OF_LOGS=$HOME/archcosta-logs.txt

GatherLogs() {
    echo "ArchCosta System Logs - $(date)" > "$FILE_OF_LOGS"
    echo "-----------------------------------" >> "$FILE_OF_LOGS"
    echo "Hardware Info:" >> "$FILE_OF_LOGS"
    inxi -Fxxc0 --za >> "$FILE_OF_LOGS" 2>/dev/null
    echo "-----------------------------------" >> "$FILE_OF_LOGS"
    echo "Journal Snippet:" >> "$FILE_OF_LOGS"
    journalctl -b -0 --no-hostname | tail -n 100 >> "$FILE_OF_LOGS"
}

Main() {
    archcosta_yad --text "Gathering logs, please wait..." --timeout 2 --no-buttons
    GatherLogs
    local url=$(archcosta-sendlog "$FILE_OF_LOGS")
    archcosta_yad --text "Logs uploaded to: $url\nURL copied to clipboard." --button=yad-ok
    echo "$url" | xclip -i -selection clipboard 2>/dev/null
}

Main "$@"
