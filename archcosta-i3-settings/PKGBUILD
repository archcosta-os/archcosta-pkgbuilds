pkgname=archcosta-i3-settings
pkgver=1.0
pkgrel=6
pkgdesc="ArchCosta i3wm configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
package() {
    # Use $startdir to reference local folders in a monorepo
    [ -d "$startdir/etc" ] && cp -r "$startdir/etc" "$pkgdir/"
    [ -d "$startdir/usr" ] && cp -r "$startdir/usr" "$pkgdir/"
}
