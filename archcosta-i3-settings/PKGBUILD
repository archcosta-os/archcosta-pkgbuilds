pkgname=archcosta-i3-settings
pkgver=1.0
pkgrel=2
pkgdesc="ArchCosta i3wm configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
package() {
    # Find etc and usr folders regardless of exact subpath
    local base_dir="$startdir"
    [ -d "$base_dir/etc" ] && cp -r "$base_dir/etc" "$pkgdir/"
    [ -d "$base_dir/usr" ] && cp -r "$base_dir/usr" "$pkgdir/"
}
