pkgname=archcosta-i3-settings
pkgver=1.0
pkgrel=5
pkgdesc="ArchCosta i3wm configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=("etc" "usr")
sha256sums=('SKIP' 'SKIP')
package() {
    [ -d "$srcdir/etc" ] && cp -r "$srcdir/etc" "$pkgdir/"
    [ -d "$srcdir/usr" ] && cp -r "$srcdir/usr" "$pkgdir/"
}
