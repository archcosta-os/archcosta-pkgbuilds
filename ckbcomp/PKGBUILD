pkgname=ckbcomp
pkgver=1.244
pkgrel=3
pkgdesc="Console keyboard layout translation tool"
arch=('any')
url="https://salsa.debian.org/installer-team/console-setup"
license=('GPL')
depends=('perl')
# Use the confirmed working Salsa URL
source=("https://salsa.debian.org/installer-team/console-setup/-/archive/${pkgver}/console-setup-${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "console-setup-${pkgver}"
  install -d "${pkgdir}/usr/bin"
  install -m755 Keyboard/ckbcomp "${pkgdir}/usr/bin/ckbcomp"
}
