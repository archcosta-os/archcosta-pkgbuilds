pkgname=ckbcomp
pkgver=1.244
pkgrel=2
pkgdesc="Console keyboard layout translation tool"
arch=('any')
url="https://salsa.debian.org/installer-team/console-setup"
license=('GPL')
depends=('perl')
# Switch to a more reliable source (Arch Linux packaging mirror)
source=("https://sources.archlinux.org/other/packages/ckbcomp/console-setup-${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
  cd "console-setup-${pkgver}"
  install -d "${pkgdir}/usr/bin"
  install -m755 Keyboard/ckbcomp "${pkgdir}/usr/bin/ckbcomp"
}
