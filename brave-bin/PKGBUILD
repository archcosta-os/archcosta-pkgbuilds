# Maintainer: ArchCosta Team
pkgname=brave-bin
pkgver=1.88.134
pkgrel=1
epoch=1
pkgdesc='Web browser that blocks ads and trackers by default (binary release)'
arch=(x86_64)
url=https://brave.com
license=(MPL2 BSD custom:chromium)
depends=(alsa-lib gtk3 libxss nss ttf-font)
provides=(brave-browser)
conflicts=(brave-browser)
options=(!strip)
source=("$pkgname.sh"
        "brave-browser.desktop"
        "${pkgname}-${pkgver}-x86_64.zip::https://github.com/brave/brave-browser/releases/download/v${pkgver}/brave-browser-${pkgver}-linux-amd64.zip")
sha256sums=('SKIP' 'SKIP' 'SKIP')

prepare() {
  [ -d brave ] || mkdir brave
  bsdtar -xf "${pkgname}-${pkgver}-x86_64.zip" -C brave
  chmod +x brave/brave
}

package() {
  install -dm0755 "$pkgdir/opt"
  cp -a brave "$pkgdir/opt/$pkgname"
  chmod 4755 "$pkgdir/opt/$pkgname/chrome-sandbox"
  install -Dm0755 "$pkgname.sh" "$pkgdir/usr/bin/brave"
  install -Dm0644 -t "$pkgdir/usr/share/applications/" "brave-browser.desktop"
  
  for size in 16 24 32 48 64 128 256; do
    install -Dm0644 "$pkgdir/opt/$pkgname/product_logo_${size}.png" \
      "$pkgdir/usr/share/icons/hicolor/${size}x${size}/apps/brave-desktop.png"
  done
}
