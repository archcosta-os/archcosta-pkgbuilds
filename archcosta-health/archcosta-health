#!/bin/bash

# ArchCosta Health Checker

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_header() {
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BLUE}  ArchCosta System Health Check${NC}"
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
}

print_ok() {
  echo -e "${GREEN}[✓]${NC} $1"
}

print_warn() {
  echo -e "${YELLOW}[!]${NC} $1"
}

print_error() {
  echo -e "${RED}[✗]${NC} $1"
}

print_info() {
  echo -e "${BLUE}[i]${NC} $1"
}

check_disk_space() {
  echo -e "${BLUE}Disk Space:${NC}"
  df -h --output=target,pcent,size,used | grep -E "^/dev|^/home|^/" | while read -r line; do
    usage=$(echo "$line" | awk '{print $2}' | tr -d '%')
    if (( usage >= 90 )); then
      print_error "$line"
    elif (( usage >= 80 )); then
      print_warn "$line"
    else
      print_ok "$line"
    fi
  done
  echo ""
}

check_memory() {
  echo -e "${BLUE}Memory Usage:${NC}"
  free -h | grep -E "^Mem:" | awk '{print "  Used: "$3" / "$2" ("int($3/$2*100)"%)"}'
  echo ""
}

check_cpu_temp() {
  echo -e "${BLUE}CPU Temperature:${NC}"
  if command -v sensors &>/dev/null; then
    temp=$(sensors 2>/dev/null | grep "Package id 0" | awk '{print $4}' | tr -d '+°C')
    if [[ -n "$temp" ]]; then
      if (( $(echo "$temp > 80" | bc -l 2>/dev/null || echo 0) )); then
        print_error "CPU Temperature: ${temp}°C"
      elif (( $(echo "$temp > 70" | bc -l 2>/dev/null || echo 0) )); then
        print_warn "CPU Temperature: ${temp}°C"
      else
        print_ok "CPU Temperature: ${temp}°C"
      fi
    else
      print_info "CPU temperature not available"
    fi
  else
    print_info "lm_sensors not installed"
  fi
  echo ""
}

check_battery() {
  echo -e "${BLUE}Battery Status:${NC}"
  if [[ -f /sys/class/power_supply/BAT0/capacity ]]; then
    capacity=$(cat /sys/class/power_supply/BAT0/capacity)
    status=$(cat /sys/class/power_supply/BAT0/status)
    echo "  Status: $status"
    echo "  Capacity: ${capacity}%"
    if (( capacity <= 10 )); then
      print_warn "Battery level critically low!"
    fi
  else
    print_info "No battery detected (desktop system)"
  fi
  echo ""
}

check_network() {
  echo -e "${BLUE}Network Status:${NC}"
  if ping -c 1 8.8.8.8 &>/dev/null; then
    print_ok "Internet connection: Active"
  else
    print_error "Internet connection: Inactive"
  fi
  echo ""
}

check_services() {
  echo -e "${BLUE}Critical Services:${NC}"
  services=("NetworkManager" "bluetooth" "cups")
  for service in "${services[@]}"; do
    if systemctl is-active --quiet "$service" 2>/dev/null; then
      print_ok "$service: Running"
    elif systemctl list-unit-files | grep -q "^$service"; then
      print_warn "$service: Not running"
    fi
  done
  echo ""
}

check_updates() {
  echo -e "${BLUE}System Updates:${NC}"
  updates=$(pacman -Qu 2>/dev/null | wc -l)
  if (( updates > 0 )); then
    print_warn "$updates package(s) can be updated"
    echo "  Run 'archcosta-update' to update"
  else
    print_ok "System is up to date"
  fi
  echo ""
}

check_smart() {
  echo -e "${BLUE}Disk Health (SMART):${NC}"
  if command -v smartctl &>/dev/null; then
    for disk in /dev/sda /dev/nvme0n1; do
      if [[ -b "$disk" ]]; then
        if smartctl -H "$disk" 2>/dev/null | grep -q "PASSED"; then
          print_ok "$disk: Healthy"
        else
          print_error "$disk: Issue detected"
        fi
      fi
    done
  else
    print_info "smartmontools not installed"
  fi
  echo ""
}

print_summary() {
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${BLUE}  Summary${NC}"
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo "  Run 'archcosta-update' to keep your system updated"
  echo "  Run 'inxi -Fxxxz' for detailed system information"
  echo ""
}

main() {
  print_header
  check_disk_space
  check_memory
  check_cpu_temp
  check_battery
  check_network
  check_services
  check_updates
  check_smart
  print_summary
}

main "$@"
