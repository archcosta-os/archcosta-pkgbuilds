pkgname=archcosta-mate-settings
pkgver=1.0
pkgrel=10
pkgdesc="ArchCosta MATE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()

package() {
    # Install etc/skel files
    if [ -d "$startdir/etc/skel" ]; then
        cp -r "$startdir/etc/skel/." "$pkgdir/etc/skel/"
    fi
    
    # Install usr files
    if [ -d "$startdir/usr" ]; then
        cp -r "$startdir/usr/." "$pkgdir/usr/"
    fi
}
