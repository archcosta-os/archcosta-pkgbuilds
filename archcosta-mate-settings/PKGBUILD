pkgname=archcosta-mate-settings
pkgver=1.0
pkgrel=7
pkgdesc="ArchCosta MATE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
prepare() {
    [ -d "$startdir/etc" ] && cp -r "$startdir/etc" "$srcdir/"
    [ -d "$startdir/usr" ] && cp -r "$startdir/usr" "$srcdir/"
}
package() {
    [ -d "$srcdir/etc" ] && cp -r "$srcdir/etc" "$pkgdir/"
    [ -d "$srcdir/usr" ] && cp -r "$srcdir/usr" "$pkgdir/"
}
