pkgname=archcosta-mate-settings
pkgver=1.0
pkgrel=2
pkgdesc="ArchCosta MATE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
package() {
    local base_dir="$startdir"
    [ -d "$base_dir/etc" ] && cp -r "$base_dir/etc" "$pkgdir/"
    [ -d "$base_dir/usr" ] && cp -r "$base_dir/usr" "$pkgdir/"
}
