# Maintainer: ArchCosta Team <archcosta@example.com>

pkgname=archcosta-hooks
pkgver=1.0.0
pkgrel=2
pkgdesc="Pacman hooks for ArchCosta system management"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL-3.0-or-later')
depends=('pacman' 'pacman-contrib' 'dracut' 'systemd' 'awk' 'archcosta-libs')
optdepends=('linux-headers: for kernel module hooks')
install="${pkgname}.install"
source=(
  "90-dracut-install.hook"
  "100-systemd-boot.hook"
  "zzz_post.hook"
  "os-release.hook"
  "orphans.hook"
  "${pkgname}.install"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
  install -d "${pkgdir}/usr/share/libalpm/hooks"
  install -d "${pkgdir}/etc/pacman.d/hooks"

  install -Dm644 orphans.hook "${pkgdir}/usr/share/libalpm/hooks/99-orphans.hook"
  install -Dm644 os-release.hook "${pkgdir}/usr/share/libalpm/hooks/20-os-release.hook"
  install -Dm644 zzz_post.hook "${pkgdir}/usr/share/libalpm/hooks/zzz_post.hook"

  install -Dm644 90-dracut-install.hook "${pkgdir}/usr/share/libalpm/hooks/90-dracut-install.hook"
  install -Dm644 100-systemd-boot.hook "${pkgdir}/usr/share/libalpm/hooks/100-systemd-boot.hook"
}
