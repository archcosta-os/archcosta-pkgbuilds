pkgname=archcosta-plasma
pkgver=1.0
pkgrel=3
pkgdesc="ArchCosta KDE Plasma Desktop meta-package"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
depends=(
  'plasma-meta'
  'lightdm'
  'lightdm-gtk-greeter'
  'dolphin'
  'ark'
  'okular'
  'gwenview'
  'spectacle'
  'plasma-pa'
  'plasma-nm'
  'power-profiles-daemon'
  'archcosta-settings'
  'archcosta-artwork'
)
package() {
  mkdir -p "$pkgdir/usr/share/archcosta"
  echo "ArchCosta Plasma Desktop Environment" > "$pkgdir/usr/share/archcosta/plasma"
}
