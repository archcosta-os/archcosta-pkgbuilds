pkgname=archcosta-cinnamon-settings
pkgver=1.0
pkgrel=6
pkgdesc="ArchCosta Cinnamon configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
package() {
    [ -d "$startdir/etc" ] && cp -r "$startdir/etc" "$pkgdir/"
    [ -d "$startdir/usr" ] && cp -r "$startdir/usr" "$pkgdir/"
}
