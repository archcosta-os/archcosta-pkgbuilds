pkgname=archcosta-xfce-config
pkgver=1.0
pkgrel=4
pkgdesc="ArchCosta XFCE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
package() {
    if [ -d "$srcdir/../archcosta-xfce-settings" ]; then
        cp -r "$srcdir/../archcosta-xfce-settings/etc" "$pkgdir/" 2>/dev/null || true
        cp -r "$srcdir/../archcosta-xfce-settings/usr" "$pkgdir/" 2>/dev/null || true
    else
        [ -d "$srcdir/../etc" ] && cp -r "$srcdir/../etc" "$pkgdir/"
        [ -d "$srcdir/../usr" ] && cp -r "$srcdir/../usr" "$pkgdir/"
    fi
}
