pkgname=archcosta-xfce-config
pkgver=1.0
pkgrel=10
pkgdesc="ArchCosta XFCE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()

package() {
    # Check if there's a subfolder with source files
    if [ -d "$startdir/archcosta-xfce-settings" ]; then
        if [ -d "$startdir/archcosta-xfce-settings/etc/skel" ]; then
            cp -r "$startdir/archcosta-xfce-settings/etc/skel/." "$pkgdir/etc/skel/"
        fi
        if [ -d "$startdir/archcosta-xfce-settings/usr" ]; then
            cp -r "$startdir/archcosta-xfce-settings/usr/." "$pkgdir/usr/"
        fi
    fi
    
    # Also check standard location (etc/usr at package root)
    if [ -d "$startdir/etc/skel" ]; then
        cp -r "$startdir/etc/skel/." "$pkgdir/etc/skel/"
    fi
    if [ -d "$startdir/usr" ]; then
        cp -r "$startdir/usr/." "$pkgdir/usr/"
    fi
}
