pkgname=archcosta-xfce-config
pkgver=1.0
pkgrel=9
pkgdesc="ArchCosta XFCE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
prepare() {
    if [ ! -d "$srcdir/etc" ]; then
        if [ -d "$startdir/archcosta-xfce-settings" ]; then
            cp -r "$startdir/archcosta-xfce-settings/etc" "$srcdir/"
            cp -r "$startdir/archcosta-xfce-settings/usr" "$srcdir/"
        else
            [ -d "$startdir/etc" ] && cp -r "$startdir/etc" "$srcdir/"
            [ -d "$startdir/usr" ] && cp -r "$startdir/usr" "$srcdir/"
        fi
    fi
}
package() {
    [ -d "$srcdir/etc" ] && cp -r "$srcdir/etc" "$pkgdir/"
    [ -d "$srcdir/usr" ] && cp -r "$srcdir/usr" "$pkgdir/"
}
