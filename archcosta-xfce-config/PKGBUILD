pkgname=archcosta-xfce-config
pkgver=1.0
pkgrel=1
pkgdesc="ArchCosta XFCE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=()
sha256sums=()
package() {
    [ -d "$startdir/archcosta-xfce-settings/etc" ] && cp -r "$startdir/archcosta-xfce-settings/etc" "$pkgdir/"
    [ -d "$startdir/archcosta-xfce-settings/usr" ] && cp -r "$startdir/archcosta-xfce-settings/usr" "$pkgdir/"
}
