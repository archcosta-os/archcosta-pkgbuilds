pkgname=archcosta-xfce-config
pkgver=1.0
pkgrel=3
pkgdesc="ArchCosta XFCE configuration files"
arch=('any')
url="https://github.com/archcosta-os/archcosta-pkgbuilds"
license=('GPL3')
source=("archcosta-xfce-settings")
sha256sums=('SKIP')
package() {
    if [ -d "$srcdir/archcosta-xfce-settings/etc" ]; then
        cp -r "$srcdir/archcosta-xfce-settings/etc" "$pkgdir/"
        cp -r "$srcdir/archcosta-xfce-settings/usr" "$pkgdir/"
    fi
}
